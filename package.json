{
  "name": "use-media-set",
  "version": "2.0.0",
  "description": "Custom hook to make components responsive to media query changes",
  "author": {
    "name": "Charley Kline",
    "email": "cvkline@gmail.com"
  },
  "license": "MIT",
  "repository": "cvkline/use-media-set",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "jsnext:main": "dist/index.es.js",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=8",
    "npm": ">=5"
  },
  "keywords": [
    "react",
    "hook",
    "hooks",
    "responsive",
    "media",
    "queries"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build",
    "start": "vite build --watch",
    "prepare": "npm run build",
    "predeploy": "cd example && npm install && npm run build",
    "deploy": "gh-pages -d example/dist",
    "postpublish": "git push --tags"
  },
  "dependencies": {
    "lodash": "^4.10"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "babel-eslint": "^10.0.1",
    "eslint": "5.16.0",
    "eslint-config-prettier": "^6",
    "eslint-config-standard": "^11.0.0",
    "eslint-config-standard-react": "^6.0.0",
    "eslint-plugin-import": "^2.13.0",
    "eslint-plugin-node": "^7.0.1",
    "eslint-plugin-prettier": "^3",
    "eslint-plugin-promise": "^4.0.0",
    "eslint-plugin-react": "^7.10.0",
    "eslint-plugin-standard": "^3.1.0",
    "gh-pages": "^5.0.0",
    "jsdom": "^25.0.1",
    "prettier": "^2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
